# Copy this file to .env and fill in real values before running docker compose
# -------------------------------------------------------------------
# Used by: backend service + seeder

# Option A: AWS RDS (production)
DATABASE_URL=mysql+pymysql://<user>:<password>@<rds-host>:3306/trax

# Option B: local MySQL (dev profile only - docker compose --profile dev up)
# DB_USER=reda
# DB_NAME=trax
# DB_PASSWORD=your-db-password-here
# DATABASE_URL=mysql+pymysql://reda:your-password%40here@db:3306/trax

# JWT - generate with: openssl rand -hex 32
SECRET_KEY=replace-with-a-strong-random-secret

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DEBUG=false

# -------------------------------------------------------------------
# Used by: frontend service

# Public IP or domain of your backend (seen by the browser)
NEXT_PUBLIC_API_URL=http://<your-server-ip>:8000

# Public IP or domain of your frontend (used by CORS in backend)
FRONTEND_URL=http://<your-server-ip>:3000